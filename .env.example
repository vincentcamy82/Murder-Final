# Obligatoire en production
ADMIN_PASSWORD=
JWT_SECRET=

# Base de données MongoDB (cluster Atlas — voir SETUP-MONGODB.md)
# Alias acceptés : MONGODB_URI, MONGO_URI, DB_URI
MONGO_URL=
DB_NAME=

# Stockage des médias (Vercel Blob, gratuit).
# Sans ce token, fallback local : webapp/.data/storage/
BLOB_READ_WRITE_TOKEN=
